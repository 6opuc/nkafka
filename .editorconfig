root = true

# All files
[*.{cs,vb,json,md}]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.{cs}]

# Indentation
indent_style = space
indent_size = 4

# Line endings
end_of_line = lf

# Whitespace
trim_trailing_whitespace = true
insert_final_newline = true

# Naming conventions
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interfaces
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.abstract_class_should_be_begins_with_abstract.severity = none
dotnet_naming_rule.abstract_class_should_be_begins_with_abstract.symbols = abstract_classes
dotnet_naming_rule.abstract_class_should_be_begins_with_abstract.style = begins_with_abstract

dotnet_naming_rule.enum_should_be_begins_with_e.severity = none
dotnet_naming_rule.enum_should_be_begins_with_e.symbols = enums
dotnet_naming_rule.enum_should_be_begins_with_e.style = begins_with_e

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = public, private, protected, internal

dotnet_naming_symbols.abstract_classes.applicable_kinds = class
dotnet_naming_symbols.abstract_classes.required_modifiers = abstract

dotnet_naming_symbols.enums.applicable_kinds = enum

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.begins_with_abstract.required_prefix = Abstract
dotnet_naming_style.begins_with_abstract.capitalization = pascal_case

dotnet_naming_style.begins_with_e.required_prefix = E
dotnet_naming_style.begins_with_e.capitalization = pascal_case

dotnet_naming_rule.locals_should_be_camel_case.severity = warning
dotnet_naming_rule.locals_should_be_camel_case.symbols = locals
dotnet_naming_rule.locals_should_be_camel_case.style = camel_case

dotnet_naming_symbols.locals.applicable_kinds = local

dotnet_naming_style.camel_case.capitalization = camel_case

# Set base severity for naming rule violations (IDE1006) to warning.
# Rules with explicit `dotnet_naming_rule.*.severity` override this.
dotnet_diagnostic.IDE1006.severity = warning

# Code style - Use predefined types
csharp_style_predefined_type_for_locals_parameters_members = true:error
csharp_style_predefined_type_for_member_access = true:error

# Code style - Use var
csharp_style_var_for_built_in_types = true:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = true:suggestion

# Organize usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_style_imports_indent = 0
dotnet_style_imports_should_align = true

# Null checks
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = true:suggestion
csharp_style_expression_bodied_operators = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion

# Pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Throw expressions
csharp_style_throw_expression = true:suggestion

# Collection expressions (C# 12+)
csharp_style_collection_expressions = true:suggestion

# Parenthesized lambda parameters
csharp_style_parenthesized_lambda_parameters = true:suggestion

# Inlined auto-properties
csharp_style_inlined_auto_properties = true:suggestion

# Using statements - block-scoped 'using' needed for Activity timing
dotnet_diagnostic.IDE0063.severity = none

# Unnecessary code
dotnet_style_unnecessary_underscore_in_interpolated_string = true:error
dotnet_style_unnecessary_cast_to_unity_type = true:error

# Preprocessor symbols
dotnet_style_predefined_preprocessor_symbols = true:error

# Required modifiers
csharp_style_require_enum_underlying_type = true:suggestion

# Space preferences
csharp_style_space_around_binary_operators = before_and_after
csharp_style_space_before_colon_in_inheritance_clause = true
csharp_style_space_after_colon_in_inheritance_clause = true
csharp_style_space_around_declaration_statements = false

# New line preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_braces = false

# Wrap preferences
csharp_prefer_braces = true:warning
csharp_prefer_simple_using_statement = true:warning
csharp_style_namespace_declarations = file_scoped:warning

# Async methods
csharp_style_throw_expression = true:suggestion

# Extension methods
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# Field prefix
dotnet_style_readonly_field = true:suggestion
